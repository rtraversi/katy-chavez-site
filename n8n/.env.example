# Copy to .env on the VPS and fill in real values. Never commit .env.
# Container reads these via docker-compose ${VAR} substitution.

# Public hostname for n8n. Must have a DNS A record pointing at this VPS.
N8N_HOST=n8n.katychavez.com

# 32+ char random string. Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Claude API key — commercial tier, never consumer claude.ai.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram bot token from @BotFather for @KCImmlaw_BOT.
# https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=

# Clerk: used to verify JWTs from the admin portal.
# Both values found in Clerk dashboard → API Keys.
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://decent-seahorse-78.clerk.accounts.dev
